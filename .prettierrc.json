{
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "overrides": [
    { "files": ["*.yml", "*.yaml"], "options": { "singleQuote": false } },
    { "files": ["*.md"], "options": { "proseWrap": "preserve" } }
  ]
}
