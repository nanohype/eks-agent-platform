{
  "name": "@eks-agent/pricing",
  "version": "0.0.0",
  "type": "module",
  "description": "Bedrock model pricing tables (per-million-token) for cost estimation. Refreshed from the AWS Pricing API via scripts/refresh-pricing.mjs.",
  "license": "Apache-2.0",
  "author": "stxkxs",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -b && rm -rf dist/data && cp -R src/data dist/data",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run src",
    "test:coverage": "vitest run src --coverage"
  },
  "dependencies": {
    "@eks-agent/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
